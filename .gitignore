# Secrets y configuración sensible
.env
.env.*
*.secret
credentials*

# Logs y estados dinámicos (no son código fuente)
*.log
logs/
engine_state.json
engine_state.json.*
trade_history.csv
last_recycle.txt

# Cache y compilados Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Backups automáticos genéricos
*.bak*
*.backup
*.old

# Excepciones: backups semánticos documentados (cláusulas de rollback)
!regime_wf/*.bak-TF-*
!regime_wf/*.bak-MR-*

# IDE y OS
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Archivos temporales
*.tmp
*.swp
*~

# Entornos virtuales
venv/
env/
.venv/

# Claude Code local state (per-user, per-machine)
.claude/

# GMM HEAD baselines restaurados (regenerables con git show HEAD:)
analysis_scripts/*/_gmm_head_baseline/
hmm_reference_env/

# Artefactos TRANSITORIOS del experimento as-of Nivel 3 (regenerables, GBs/celda).
# Barrera estructural: durante el run de 13 celdas hay múltiples commits; un
# `git add -A` descuidado no debe poder stagear los parts (~222GB/celda).
# NO afecta a lo que SÍ se versiona: sellados nivel3_resmoke_trades_*.json,
# docs/veredicto *.md, harness *.py/*.sh (viven en el audit dir, no en sandbox),
# ni a data_cache/ (canónico, 57 parquets trackeados — NO se ignora).
asof_sandbox/
_parts_*/
audit_forense_gap_20260612/binance_deep/
audit_forense_gap_20260612/crash_evidence/
